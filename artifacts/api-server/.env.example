# Example environment variables for local development
# Replace values before using in production

# Postgres connection string (required)
# Format: postgres://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgres://postgres:1234@localhost:5432/mariela-inmobiliaria
JWT_SECRET=change-me-to-a-strong-secret
PORT=8080

# Optional Cloudinary settings for production image storage.
# If these are set, uploads will be sent to Cloudinary instead of local disk.
# Use either CLOUDINARY_URL or the individual credentials below.
CLOUDINARY_URL=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=